{
    "name": "tanstarter",
    "private": true,
    "workspaces": {
        "packages": [
            "packages/*",
            "apps/*",
            "tooling/*"
        ],
        "catalog": {
            "@base-ui/react": "^1.2.0",
            "@commitlint/cli": "^20.4.3",
            "@commitlint/config-conventional": "^20.4.3",
            "@fontsource-variable/inter": "^5.2.8",
            "@phosphor-icons/react": "^2.1.10",
            "@react-email/components": "^1.0.8",
            "@react-email/render": "^2.0.4",
            "@tailwindcss/vite": "^4.2.1",
            "@tanstack/devtools-vite": "^0.5.3",
            "@tanstack/eslint-plugin-query": "^5.91.4",
            "@tanstack/eslint-plugin-router": "^1.161.4",
            "@tanstack/react-devtools": "^0.9.10",
            "@tanstack/react-form-devtools": "^0.2.17",
            "@tanstack/react-form-start": "^1.28.4",
            "@tanstack/react-query": "^5.90.21",
            "@tanstack/react-query-devtools": "^5.91.3",
            "@tanstack/react-router": "^1.166.2",
            "@tanstack/react-router-devtools": "^1.166.2",
            "@tanstack/react-router-ssr-query": "^1.166.2",
            "@tanstack/react-start": "^1.166.2",
            "@types/bun": "^1.3.10",
            "@types/node": "^25.3.5",
            "@types/react": "^19.2.14",
            "@types/react-dom": "^19.2.3",
            "@vitejs/plugin-react": "^5.1.4",
            "babel-plugin-react-compiler": "^1.0.0",
            "better-auth": "beta",
            "class-variance-authority": "^0.7.1",
            "clsx": "^2.1.1",
            "date-fns": "^4.1.0",
            "eslint-plugin-react-hooks": "^7.0.1",
            "eslint-plugin-turbo": "^2.8.14",
            "husky": "^9.1.7",
            "lint-staged": "^16.3.2",
            "motion": "^12.35.0",
            "react-use-measure": "^2.1.7",
            "nanoid": "^5.1.6",
            "nitro": "^3.0.1-alpha.2",
            "oxfmt": "^0.36.0",
            "oxlint": "^1.51.0",
            "oxlint-tsgolint": "^0.16.0",
            "react": "^19.2.4",
            "react-dom": "^19.2.4",
            "react-email": "^5.2.9",
            "shadcn": "^4.0.0",
            "sonner": "^2.0.7",
            "tailwind-merge": "^3.5.0",
            "tailwindcss": "^4.2.1",
            "turbo": "^2.8.14",
            "tw-animate-css": "^1.4.0",
            "typescript": "^6.0.0-beta",
            "vite": "^8.0.0-beta.16",
            "zod": "^4.3.6",
            "mongodb": "^7.1.0"
        }
    },
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev --parallel",
        "dev:web": "turbo run dev --filter=@repo/web",
        "lint": "oxlint --type-aware --type-check",
        "lint:fix": "oxlint --type-aware --type-check --fix",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "check": "turbo run quality",
        "prepare": "husky",
        "deps": "bunx taze@latest -Ilwr --peer",
        "deps:major": "bunx taze@latest major -Ilwr --peer",
        "ui": "bun run --filter=@repo/ui ui",
        "ui:web": "bun run --filter=@repo/web run ui",
        "auth:secret": "bunx @better-auth/cli@latest secret",
        "skills": "bunx skills@latest"
    },
    "devDependencies": {
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@tanstack/eslint-plugin-query": "catalog:",
        "@tanstack/eslint-plugin-router": "catalog:",
        "eslint-plugin-react-hooks": "catalog:",
        "eslint-plugin-turbo": "catalog:",
        "husky": "catalog:",
        "lint-staged": "catalog:",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "oxlint-tsgolint": "catalog:",
        "turbo": "catalog:"
    },
    "overrides": {
        "typescript": "^6.0.0-beta",
        "vite": "^8.0.0-beta.16"
    },
    "lint-staged": {
        "*": "oxfmt --no-error-on-unmatched-pattern"
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "bun@1.3.10",
    "patchedDependencies": {
        "nitro@3.0.1-alpha.2": "patches/nitro@3.0.1-alpha.2.patch"
    }
}
