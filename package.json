    "scripts": {
        "build": "turbo run build",
        "check": "turbo run quality",
        "docker:build": "node tooling/scripts/docker-build.mjs",
        "docker:test:down": "docker compose -f docker-compose.test.yml down --remove-orphans",
        "docker:test:logs": "docker compose -f docker-compose.test.yml logs -f --tail=200",
        "docker:test:ps": "docker compose -f docker-compose.test.yml ps",
        "docker:test:reset": "docker compose -f docker-compose.test.yml down -v --remove-orphans",
        "docker:test:up": "docker compose -f docker-compose.test.yml up -d --build",
        "deps": "bunx taze@latest -Ilwr --peer",
        "deps:major": "bunx taze@latest major -Ilwr --peer",
        "dev": "turbo run dev",
        "dev:web": "turbo run dev --filter=@repo/web",
        "faviconize": "turbo run faviconize",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint --type-aware --type-check",
        "lint:fix": "oxlint --type-aware --type-check --fix",
        "prepare": "husky",
        "test:e2e": "bunx playwright test --config apps/web/playwright.config.ts",
        "test:harness:down": "bun run docker:test:down",
        "test:harness:prepare": "bun run tooling/testing/prepare.mjs",
        "test:harness:seed": "bun run tooling/testing/seed.mjs",
        "test:harness:up": "bun run docker:test:up",
        "test:integration": "bun test apps/web/tests/integration",
        "test:security": "bun run test:harness:prepare && bun run test:integration && bun run test:e2e",
        "ui": "bun run --filter=@repo/ui ui",
        "ui:web": "bun run --filter=@repo/web run ui"
    },
    "devDependencies": {
        "@commitlint/cli": "catalog:",
        "@commitlint/config-conventional": "catalog:",
        "@realfavicongenerator/generate-favicon": "catalog:",
