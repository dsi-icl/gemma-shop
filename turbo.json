{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "globalPassThroughEnv": [
        "BASE_URL",
        "CI",
        "NODE_ENV",
        "BUILD_SOURCEMAPS",
        "APP_COMMIT_SHA",
        "GIT_COMMIT",
        "GITHUB_SHA",
        "GITHUB_HEAD_SHA",
        "CI_COMMIT_SHA",
        "CI_COMMIT_SHORT_SHA",
        "BUILD_SOURCEVERSION",
        "BUILDKITE_COMMIT",
        "CIRCLE_SHA1",
        "DRONE_COMMIT_SHA",
        "BITBUCKET_COMMIT",
        "VERCEL_GIT_COMMIT_SHA",
        "CF_PAGES_COMMIT_SHA",
        "TRAVIS_COMMIT",
        "SOURCE_VERSION",
        "PROD",
        "TEST_BASE_URL",
        "TEST_PREPARE_DELAY_MS",
        "TEST_PREPARE_MAX_ATTEMPTS",
        "WEB_HOST_PORT",
        "YJS_DEBUG",
        "ALLOWED_HOSTS",
        "PROXY_ALLOWED_REFERRERS",
        "PROXY_ALLOW_MISSING_REFERRER",
        "PROXY_FETCH_TIMEOUT_MS",
        "PROXY_MAX_BYTES",
        "FFMPEG_PATH",
        "TRUSTED_ORIGINS",
        "STRICT_BLOCKING",
        "TRUST_FORWARDED_HEADERS",
        "RATE_LIMIT_PER_MINUTE",
        "WS_RATE_LIMIT_STRIKE_LIMIT",
        "WEB_SCREENSHOT_ALLOWLIST",
        "WEB_SCREENSHOT_RATE_LIMIT_PER_MIN",
        "SCREENSHOT_INTERNAL_TOKEN"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [
                "dist/**",
                ".vercel/**",
                ".nitro/**",
                ".wrangler/**",
                ".output/**",
                ".tanstack/**"
            ],
            "env": ["SERVER_*", "VITE_*"]
        },
        "//#quality": {
            "dependsOn": ["//#lint", "//#format"]
        },
        "//#quality:fix": {
            "dependsOn": ["//#lint:fix", "//#format"]
        },
        "//#lint": {},
        "//#lint:fix": {
            "cache": false
        },
        "//#format": {
            "cache": false
        },
        "//#format:check": {},
        "dev": {
            "inputs": ["$TURBO_DEFAULT$", ".env"],
            "cache": false,
            "persistent": true
        },
        "faviconize": {
            "inputs": ["$TURBO_DEFAULT$", ".env"],
            "cache": false,
            "persistent": true
        },
        "preview": {
            "inputs": ["$TURBO_DEFAULT$"],
            "cache": false,
            "persistent": true
        }
    }
}
